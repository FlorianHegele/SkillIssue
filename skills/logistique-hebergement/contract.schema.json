{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "logistique-hebergement — sortie",
  "type": "object",
  "required": ["lieu", "hebergement"],
  "additionalProperties": false,
  "properties": {
    "lieu": { "$ref": "#/$defs/lieu" },
    "skill": { "$ref": "#/$defs/skill" },
    "hebergement": { "oneOf": [ { "$ref": "#/$defs/hebergement" }, { "$ref": "#/$defs/erreur" } ] }
  },
  "$defs": {
    "skill": {
      "type": "object",
      "required": ["nom", "version", "version_distante", "maj_disponible", "verifie_le", "source"],
      "additionalProperties": false,
      "properties": {
        "nom": { "type": ["string", "null"] },
        "version": { "type": "string" },
        "version_distante": { "type": "string" },
        "maj_disponible": { "type": "boolean" },
        "message": { "type": ["string", "null"] },
        "verifie_le": { "type": ["string", "null"] },
        "source": { "enum": ["reseau", "cache", "local-seul"] }
      }
    },
    "lieu": {
      "type": "object",
      "required": ["commune", "code_insee", "lat", "lon"],
      "additionalProperties": false,
      "properties": {
        "commune": { "type": ["string", "null"] },
        "code_insee": { "type": ["string", "null"] },
        "lat": { "type": "number" },
        "lon": { "type": "number" }
      }
    },
    "erreur": {
      "type": "object",
      "required": ["error"],
      "properties": {
        "error": { "type": "string" },
        "detail": {}
      }
    },
    "site": {
      "type": "object",
      "required": ["osm_id", "type", "nom", "lat", "lon", "distance_km",
                   "capacite", "capacite_source", "capacite_methode", "surface_m2", "tags"],
      "additionalProperties": false,
      "properties": {
        "osm_id": { "type": "string" },
        "type": { "enum": ["hôtel", "gymnase", "école", "salle_communale"] },
        "nom": { "type": ["string", "null"] },
        "lat": { "type": ["number", "string"] },
        "lon": { "type": ["number", "string"] },
        "distance_km": { "type": ["number", "string"] },
        "capacite": { "type": ["number", "string"] },
        "capacite_source": { "enum": ["osm", "estimee", "indisponible"] },
        "capacite_methode": { "type": "string" },
        "surface_m2": { "type": ["number", "string"] },
        "tags": { "type": "object" },
        "geometry": {
          "type": ["array", "null"],
          "items": {
            "type": "object",
            "properties": { "lat": { "type": "number" }, "lon": { "type": "number" } }
          }
        }
      }
    },
    "resume": {
      "type": "object",
      "required": ["sites_total", "hotels", "gymnases", "ecoles", "salles_communales",
                   "capacite_fiable_totale", "capacite_majorant_parcelles",
                   "sites_capacite_majorant", "sites_sans_capacite"],
      "additionalProperties": false,
      "properties": {
        "sites_total": { "type": "integer" },
        "hotels": { "type": "integer" },
        "gymnases": { "type": "integer" },
        "ecoles": { "type": "integer" },
        "salles_communales": { "type": "integer" },
        "capacite_fiable_totale": { "type": "integer" },
        "capacite_majorant_parcelles": { "type": "integer" },
        "sites_capacite_majorant": { "type": "integer" },
        "sites_sans_capacite": { "type": "integer" }
      }
    },
    "hebergement": {
      "type": "object",
      "required": ["rayon_m", "resume", "sites", "note"],
      "additionalProperties": false,
      "properties": {
        "rayon_m": { "type": "integer" },
        "resume": { "$ref": "#/$defs/resume" },
        "sites": { "type": "array", "items": { "$ref": "#/$defs/site" } },
        "note": { "type": "string" }
      }
    }
  }
}
