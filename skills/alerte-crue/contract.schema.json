{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "alerte-crue — sortie",
  "type": "object",
  "required": ["lieu", "fuseau"],
  "additionalProperties": false,
  "properties": {
    "lieu": { "$ref": "#/$defs/lieu" },
    "skill": { "$ref": "#/$defs/skill" },
    "fuseau": { "type": "string", "description": "Fuseau IANA local du point ; référentiel de TOUS les horodatages de la sortie (heures de pluie, dates hydro)." },
    "vigilance": { "oneOf": [ { "$ref": "#/$defs/vigilance" }, { "$ref": "#/$defs/erreur" } ] },
    "hydro": { "oneOf": [ { "$ref": "#/$defs/hydro" }, { "$ref": "#/$defs/erreur" } ] },
    "pluie": { "oneOf": [ { "$ref": "#/$defs/pluie" }, { "$ref": "#/$defs/erreur" } ] }
  },
  "$defs": {
    "skill": {
      "type": "object",
      "required": ["nom", "version", "version_distante", "maj_disponible", "verifie_le", "source"],
      "additionalProperties": false,
      "properties": {
        "nom": { "type": ["string", "null"] },
        "version": { "type": "string" },
        "version_distante": { "type": "string" },
        "maj_disponible": { "type": "boolean" },
        "message": { "type": ["string", "null"] },
        "verifie_le": { "type": ["string", "null"] },
        "source": { "enum": ["reseau", "cache", "local-seul"] }
      }
    },
    "lieu": {
      "type": "object",
      "required": ["commune", "code_insee", "lat", "lon"],
      "additionalProperties": false,
      "properties": {
        "commune": { "type": ["string", "null"] },
        "code_insee": { "type": ["string", "null"] },
        "lat": { "type": "number" },
        "lon": { "type": "number" }
      }
    },
    "erreur": {
      "type": "object",
      "required": ["error"],
      "additionalProperties": false,
      "properties": {
        "error": { "type": "string" },
        "detail": {},
        "indice": { "type": "string" },
        "troncon_le_plus_proche": {}
      }
    },
    "vigilance": {
      "type": "object",
      "required": ["couleur", "distance_km"],
      "additionalProperties": false,
      "properties": {
        "couleur": { "enum": ["vert", "jaune", "orange", "rouge", "inconnu"] },
        "distance_km": { "type": "number" },
        "niveau": { "type": ["integer", "null"] },
        "troncon": { "type": ["string", "null"] }
      }
    },
    "station_hydro": {
      "type": "object",
      "required": ["station", "distance_km"],
      "additionalProperties": false,
      "properties": {
        "station": { "type": "string" },
        "distance_km": { "type": "number" },
        "nom": { "type": ["string", "null"] },
        "hauteur_mm": { "type": ["number", "string"] },
        "debit_ls": { "type": ["number", "string"] },
        "date_hauteur": { "type": ["string", "null"] },
        "date_debit": { "type": ["string", "null"] }
      }
    },
    "hydro": {
      "type": "object",
      "required": ["stations", "stations_dans_rayon"],
      "additionalProperties": false,
      "properties": {
        "stations": { "type": "array", "items": { "$ref": "#/$defs/station_hydro" } },
        "stations_dans_rayon": { "type": "integer" }
      }
    },
    "heure_pluie": {
      "type": "object",
      "required": ["heure", "precipitation_mm"],
      "additionalProperties": false,
      "properties": {
        "heure": { "type": "string" },
        "precipitation_mm": { "type": "number" }
      }
    },
    "creneau": {
      "type": "object",
      "required": ["debut", "fin", "cumul_mm"],
      "additionalProperties": false,
      "properties": {
        "debut": { "type": "string" },
        "fin": { "type": "string" },
        "cumul_mm": { "type": "number" }
      }
    },
    "pluie": {
      "type": "object",
      "required": ["cumul_prochaines_24h_mm", "seuil_mm", "heures_pluvieuses", "modele", "unite", "creneaux"],
      "additionalProperties": false,
      "properties": {
        "cumul_prochaines_24h_mm": { "type": ["number", "string"] },
        "seuil_mm": { "type": "number" },
        "modele": { "type": "string" },
        "unite": { "type": "string" },
        "pic": {
          "oneOf": [ { "$ref": "#/$defs/heure_pluie" }, { "type": "null" } ]
        },
        "creneaux": {
          "type": "array",
          "items": { "$ref": "#/$defs/creneau" }
        },
        "heures_pluvieuses": {
          "type": "array",
          "items": { "$ref": "#/$defs/heure_pluie" }
        },
        "par_heure": {
          "type": "array",
          "items": { "$ref": "#/$defs/heure_pluie" }
        }
      }
    }
  }
}
